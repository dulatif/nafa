# ============================================
# Application
# ============================================
APP_NAME="NestJS Starter"
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=*

# ============================================
# Database
# ============================================
DATABASE_URL="file:./dev.db"

# ============================================
# Authentication (JWT)
# ============================================
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# ============================================
# Storage
# ============================================
# Driver: 'local' or 's3'
STORAGE_DRIVER=local

# Local storage
STORAGE_LOCAL_PATH=./uploads
STORAGE_SERVE_ROOT=/uploads

# S3 storage (optional)
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=

# File upload limits
STORAGE_MAX_FILE_SIZE=10485760
STORAGE_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# ============================================
# Swagger / API Documentation
# ============================================
SWAGGER_TITLE="NestJS Starter API"
SWAGGER_DESCRIPTION="API documentation for NestJS Starter Kit"
SWAGGER_VERSION=1.0
SWAGGER_PATH=api/docs
SWAGGER_ENABLED=true
